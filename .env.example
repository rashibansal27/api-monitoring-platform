# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="API Monitoring Platform"
APP_ENV=development           # development | staging | production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENABLE_SCHEDULER=true

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme
# ES_API_KEY=          # Use instead of username/password if preferred
ES_INDEX_PATTERN=payment-logs-*
ES_POLL_LOOKBACK_SECONDS=60
ES_MAX_HITS=1000
ES_TIMEOUT_SECONDS=10

# ── Prometheus ────────────────────────────────────────────────────────────────
PROM_URL=http://localhost:9090
PROM_TIMEOUT_SECONDS=10
PROM_STEP_SECONDS=60

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=api-monitoring-consumer
KAFKA_TOPICS=["payment.transactions","gateway.logs"]
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_USE_MOCK=true           # true = use mock queue; false = real Kafka

# ── Database (TimescaleDB / PostgreSQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_monitoring
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
